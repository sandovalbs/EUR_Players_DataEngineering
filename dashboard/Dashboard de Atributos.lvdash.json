{
  "datasets": [
    {
      "name": "player_attributes_bar",
      "displayName": "Player Attributes",
      "queryLines": [
        "SELECT\n",
        "  `player_name`,\n",
        "  `avg_acceleration`\n",
        "FROM\n",
        "  `catalog_empresa`.`golden`.`player_attributes`\n",
        "WHERE\n",
        "  `player_name` IS NOT NULL\n",
        "  AND `avg_acceleration` IS NOT NULL"
      ]
    },
    {
      "name": "player_attributes_multi_line",
      "displayName": "Player Attributes Multi Line",
      "queryLines": [
        "SELECT\n",
        "  `player_name`,\n",
        "  'avg_acceleration' AS `metric`,\n",
        "  `avg_acceleration` AS `metric_value`\n",
        "FROM\n",
        "  `catalog_empresa`.`golden`.`player_attributes`\n",
        "WHERE\n",
        "  `player_name` IS NOT NULL\n",
        "  AND `avg_acceleration` IS NOT NULL\n",
        "UNION ALL\n",
        "SELECT\n",
        "  `player_name`,\n",
        "  'avg_ball_control' AS `metric`,\n",
        "  `avg_ball_control` AS `metric_value`\n",
        "FROM\n",
        "  `catalog_empresa`.`golden`.`player_attributes`\n",
        "WHERE\n",
        "  `player_name` IS NOT NULL\n",
        "  AND `avg_ball_control` IS NOT NULL\n",
        "UNION ALL\n",
        "SELECT\n",
        "  `player_name`,\n",
        "  'avg_dribbling' AS `metric`,\n",
        "  `avg_dribbling` AS `metric_value`\n",
        "FROM\n",
        "  `catalog_empresa`.`golden`.`player_attributes`\n",
        "WHERE\n",
        "  `player_name` IS NOT NULL\n",
        "  AND `avg_dribbling` IS NOT NULL\n",
        "UNION ALL\n",
        "SELECT\n",
        "  `player_name`,\n",
        "  'avg_finishing' AS `metric`,\n",
        "  `avg_finishing` AS `metric_value`\n",
        "FROM\n",
        "  `catalog_empresa`.`golden`.`player_attributes`\n",
        "WHERE\n",
        "  `player_name` IS NOT NULL\n",
        "  AND `avg_finishing` IS NOT NULL\n",
        "UNION ALL\n",
        "SELECT\n",
        "  `player_name`,\n",
        "  'avg_free_kick_accuracy' AS `metric`,\n",
        "  `avg_free_kick_accuracy` AS `metric_value`\n",
        "FROM\n",
        "  `catalog_empresa`.`golden`.`player_attributes`\n",
        "WHERE\n",
        "  `player_name` IS NOT NULL\n",
        "  AND `avg_free_kick_accuracy` IS NOT NULL"
      ]
    }
  ],
